<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
<Document>
  <name>Fernanda e Isabella · Lago di Como · Jun 2026</name>

  <!-- ═══ ESTILOS ═══ -->

  <Style id="s_hotel">
    <IconStyle>
      <color>ffc9a227</color>
      <scale>1.2</scale>
      <Icon><href>https://maps.google.com/mapfiles/kml/shapes/lodging.png</href></Icon>
    </IconStyle>
    <LabelStyle><scale>0.9</scale></LabelStyle>
  </Style>

  <Style id="s_porto">
    <IconStyle>
      <color>ff1a3a5c</color>
      <scale>1.2</scale>
      <Icon><href>https://maps.google.com/mapfiles/kml/shapes/ferry.png</href></Icon>
    </IconStyle>
    <LabelStyle><scale>0.9</scale></LabelStyle>
  </Style>

  <Style id="s_atracao">
    <IconStyle>
      <color>ff2a6a3a</color>
      <scale>1.2</scale>
      <Icon><href>https://maps.google.com/mapfiles/kml/shapes/star.png</href></Icon>
    </IconStyle>
    <LabelStyle><scale>0.9</scale></LabelStyle>
  </Style>

  <Style id="s_restaurante">
    <IconStyle>
      <color>ffb05a1a</color>
      <scale>1.1</scale>
      <Icon><href>https://maps.google.com/mapfiles/kml/shapes/dining.png</href></Icon>
    </IconStyle>
    <LabelStyle><scale>0.9</scale></LabelStyle>
  </Style>

  <Style id="s_bar">
    <IconStyle>
      <color>ffb05a1a</color>
      <scale>1.1</scale>
      <Icon><href>https://maps.google.com/mapfiles/kml/shapes/bar.png</href></Icon>
    </IconStyle>
    <LabelStyle><scale>0.9</scale></LabelStyle>
  </Style>

  <Style id="s_passeio">
    <IconStyle>
      <color>ff1a3a5c</color>
      <scale>1.1</scale>
      <Icon><href>https://maps.google.com/mapfiles/kml/shapes/camera.png</href></Icon>
    </IconStyle>
    <LabelStyle><scale>0.9</scale></LabelStyle>
  </Style>

  <Style id="s_transfer">
    <IconStyle>
      <color>ff555555</color>
      <scale>1.0</scale>
